# Token for requesting data from the 5calls API
# Get yours here: https://5calls.org/representatives-api/
FIVE_CALLS_TOKEN=<TOKEN>

# Token for requesting data from the congress.gov API
# Get yours here: https://api.congress.gov/sign-up/
CONGRESS_GOV_API_KEY=<TOKEN>

# Maximum number of roll call votes to check per congressional session when fetching
# a member's voting record. Lower values reduce API calls during development.
# Defaults to 100 when not set. Set to 20 for local development.
VOTE_FETCH_LIMIT=20

# Set to "true" to bypass all Voteprint caching layers and always fetch fresh data.
# Useful when testing new vote data without waiting for the 24-hour cache to expire.
VOTEPRINT_BYPASS_CACHE=false

# Set to "true" to force Vercel Blob cache in local development (requires BLOB_READ_WRITE_TOKEN).
# In production this is always true. Defaults to false.
FORCE_BLOB_CACHE=false

# Token for requesting data from the Anthropic API
# Get yours here: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=<KEY>